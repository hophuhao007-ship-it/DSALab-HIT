#include <iostream>
using namespace std;

int main() {

    int n;

    cout << "Nhap kich thuoc ma tran: ";
    cin >> n;

    int A[10][10];
    int B[10][10];
    int C[10][10];

    // ==========================
    // NHAP MA TRAN A
    // ==========================
    cout << "\nNhap ma tran A:\n";

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {

            cout << "A[" << i << "][" << j << "] = ";
            cin >> A[i][j];
        }
    }

    // ==========================
    // NHAP MA TRAN B
    // ==========================
    cout << "\nNhap ma tran B:\n";

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {

            cout << "B[" << i << "][" << j << "] = ";
            cin >> B[i][j];
        }
    }

    // ==========================
    // NHAN MA TRAN
    // ==========================
    for (int i = 0; i < n; i++) {

        for (int j = 0; j < n; j++) {

            C[i][j] = 0;

            for (int k = 0; k < n; k++) {

                C[i][j] += A[i][k] * B[k][j];
            }
        }
    }

    // ==========================
    // XUAT MA TRAN KET QUA
    // ==========================
    cout << "\n===== MA TRAN KET QUA =====\n";

    for (int i = 0; i < n; i++) {

        for (int j = 0; j < n; j++) {

            cout << C[i][j] << "\t";
        }

        cout << endl;
    }

    return 0;
}
